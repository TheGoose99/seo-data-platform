## SEO Data Platform — local env example

# Public site URL (used for redirects and OAuth callback construction)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth (GSC + GBP)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Google Maps Platform (Places autocomplete + details)
GOOGLE_MAPS_API_KEY=

# DataForSEO (SERP grid)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# App-level encryption key for storing OAuth refresh tokens (base64; 32+ bytes)
TOKEN_ENC_KEY_BASE64=

# Anthropic (CloseBy generation — run-with-toon.ts)
ANTHROPIC_API_KEY=
# Optional override (default: claude-sonnet-4-20250514)
ANTHROPIC_MODEL=
# Optional sampling 0–1 (omit for API default). Personality in TOON is the main uniqueness lever.
ANTHROPIC_TEMPERATURE=

# Website generation: mock Cal fields in merged JSON (lib/website/mocks). Omit or leave unset (default: mock on). Set to 0 only when
# you merge public Cal from DB via `run-with-toon --client-id=<uuid>` (requires NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY).
# MOCK_CAL_INTEGRATIONS=0

# --- Website template + onboarding (scripting/website) ---

# Maintainer-only: path to a full Next app when running `npm run template:zip` to refresh website-app-template.zip (not used in production onboarding)
WEBSITE_TEMPLATE_SOURCE=

# Merged ClientConfig JSON path — usually set by onboard-client.mjs; hooks/post-unzip.mjs copies into the unzipped app
MERGED_CLIENT_PATH=
# Optional: destination inside app (default: config/clients/merged-client.json)
MERGED_CLIENT_DEST=

# Vercel CLI — copy into your local `.env.local` (never commit real values)
# Required for `npm run onboard:client` to run `vercel deploy` non-interactively:
#   VERCEL_TOKEN — https://vercel.com/account/tokens
# Strongly recommended (same project every run; the packed zip excludes `.vercel/`):
#   VERCEL_ORG_ID — team slug (e.g. my-team) or team id; required for `vercel deploy --scope` in non-interactive mode
#   VERCEL_PROJECT_ID — Project → Settings → General (optional; helps CLI target one project)
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Git-linked website deploy (default when both are set): private GitHub repo named after merged ClientConfig slug, then Vercel project via API
# One-time: connect GitHub to your Vercel team (Dashboard → Team → Git).
# GITHUB_TOKEN — classic PAT with `repo`, or fine-grained with repo create + contents write for GITHUB_OWNER
# GITHUB_OWNER — GitHub user login or org name (repo will be GITHUB_OWNER/<sanitized-slug>)
# GITHUB_REPO_EXISTS=reuse — optional; if the repo already exists, skip create and only push (empty repo or you resolve conflicts)
# GITHUB_DEFAULT_BRANCH=main — optional
# Optional commit author for the initial git commit (defaults shown in git-init-and-push.mjs)
# GIT_AUTHOR_NAME=
# GIT_AUTHOR_EMAIL=
GITHUB_TOKEN=
GITHUB_OWNER=

# Legacy file upload deploy (skip GitHub): set to 1 or pass --vercel-cli-upload to onboard / run-template-pipeline
# VERCEL_USE_CLI_UPLOAD=1

# --- Client site (website template) — copied to each new Vercel project after Git-linked create ---
# Put the same values you use on closeby-demo-project (or run `vercel env pull` from that project into this file).
# Optional: VERCEL_SYNC_EXTRA_KEYS=FOO,BAR — extra env keys to upsert onto the new project
# VERCEL_SKIP_ENV_SYNC=1 — do not POST env / redeploy (advanced)
# VERCEL_SKIP_REDEPLOY=1 — POST env only; skip git redeploy (first deploy may lack secrets until manual redeploy)
# CAL_API_KEY=
# CAL_WEBHOOK_SECRET=
# CLIENT_SLUG= — overridden per run by merged client slug
# NEXT_PUBLIC_SITE_URL= — overridden from deployment URL when available
# RESEND_API_KEY=
# RESEND_FROM=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# QSTASH_TOKEN=
# QSTASH_FORWARD_SECRET=

# MongoDB — Claude API usage logs (collection `claude_api`; set `MONGODB_DB` if URI has no database path)
MONGODB_URI=
MONGODB_DB=seo_data_platform
# Optional override (default: claude_api)
# MONGODB_CLAUDE_COLLECTION=